# Copy this file to `.env` and fill in your key. `.env` is gitignored.
#
# Google Maps Platform API key with the *Geocoding API* enabled. Used by
# `--address` to turn a street address / place name into a coordinate.
# https://developers.google.com/maps/documentation/geocoding/get-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
